# Copy this file to .env and fill in your values.
# .env is NOT committed to version control.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=cloudcampus
DB_USERNAME=postgres
DB_PASSWORD=change-me-strong-password

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-secure-random-value-at-least-32-bytes-long
JWT_ACCESS_TOKEN_EXPIRATION_MS=3600000

# ── Bootstrap Super Admin ─────────────────────────────────────────────────────
BOOTSTRAP_ADMIN_USERNAME=superadmin
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-admin-password
BOOTSTRAP_ADMIN_ROLE=SUPER_ADMIN
