# ══════════════════════════════════════════════════════════════════════════════
# CloudCampus — Environment Variables Reference (CC-1906)
#
# Copy this file to .env and fill in real values for your environment.
# NEVER commit .env to version control — it is listed in .gitignore.
#
# Generate random secrets:
#   openssl rand -hex 32    →  64-char hex string (256-bit)
#   openssl rand -hex 16    →  32-char hex string (128-bit)
#
# Production secret storage:
#   • HashiCorp Vault  — mount secrets as env vars via vault agent injector
#   • AWS Secrets Manager — sync via External Secrets Operator (ESO)
#   • Kubernetes Secrets — base64-encoded, injected as env vars in pod spec
#
# All <generate: ...> placeholders MUST be replaced before production use.
# The app will refuse to start if dev defaults are detected in non-dev profiles.
# ══════════════════════════════════════════════════════════════════════════════

# ── Active Spring profile ─────────────────────────────────────────────────────
# Allowed values: dev | staging | prod
# In dev, secrets validation is skipped and defaults are used.
SPRING_PROFILES_ACTIVE=prod

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by both the Spring datasource and the pgbackup sidecar.
POSTGRES_DB=cloudcampus
POSTGRES_USER=cloudcampus
POSTGRES_PASSWORD=<generate: openssl rand -hex 32>

# Spring datasource (these should match the Postgres values above)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/cloudcampus
SPRING_DATASOURCE_USERNAME=cloudcampus
SPRING_DATASOURCE_PASSWORD=<same as POSTGRES_PASSWORD>
# Path to the RDS / PostgreSQL CA certificate bundle (for verify-full TLS in prod)
# Download from: https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
DB_SSL_ROOT_CERT=/etc/ssl/certs/rds-ca.pem

# ── JWT ───────────────────────────────────────────────────────────────────────
# Minimum 32 characters. Used to sign/verify all access and refresh tokens.
# Rotating this value invalidates all existing sessions.
JWT_SECRET=<generate: openssl rand -hex 32>

# ── PII Field Encryption ──────────────────────────────────────────────────────
# AES-256-GCM key for Student.phone/address and Staff.phone/email/address.
# WARNING: Changing this key makes all existing encrypted rows unreadable.
# Store the old key in a key archive before rotation and run a re-encryption job.
ENCRYPTION_SECRET=<generate: openssl rand -hex 32>

# ── Bootstrap Super Admin ─────────────────────────────────────────────────────
# Runs ONCE on first boot if this password is non-empty. Idempotent after that.
# Leave blank to skip bootstrap (safe for environments with an existing DB).
BOOTSTRAP_ADMIN_USERNAME=superadmin
BOOTSTRAP_ADMIN_PASSWORD=<strong password — min 12 chars, mixed case, digits, symbols>

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for rate limiting, OTP TTL, and API response caching.
# For Redis Cloud or ElastiCache, set SPRING_DATA_REDIS_URL instead.
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
REDIS_PASSWORD=<generate: openssl rand -hex 32>
SPRING_DATA_REDIS_PASSWORD=<same as REDIS_PASSWORD>

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
# Used for durable notification queues (email, SMS) with dead-letter routing.
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=cloudcampus
RABBITMQ_PASSWORD=<generate: openssl rand -hex 16>

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
# Transactional email for OTP, welcome, and notification messages.
# SendGrid: MAIL_HOST=smtp.sendgrid.net, MAIL_PORT=587, MAIL_USERNAME=apikey
# AWS SES:  MAIL_HOST=email-smtp.<region>.amazonaws.com, MAIL_PORT=587
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=<SendGrid API key or SMTP password>
MAIL_FROM=noreply@cloudcampus.io

# ── Firebase Push Notifications (optional) ────────────────────────────────────
# Set APP_FIREBASE_ENABLED=true and provide the service-account JSON path
# to enable FCM/APNs push dispatch (CC-1003).
APP_FIREBASE_ENABLED=false
APP_FIREBASE_CREDENTIALS_PATH=/run/secrets/firebase-service-account.json
APP_FIREBASE_PROJECT_ID=

# ── Grafana ───────────────────────────────────────────────────────────────────
# Admin password for Grafana web UI. NEVER use "admin" in staging/prod.
GF_SECURITY_ADMIN_PASSWORD=<generate: openssl rand -hex 16>

# ── MinIO / S3 (backup storage) ───────────────────────────────────────────────
# Used by the pgbackup sidecar to store pg_dump archives.
# For AWS S3: MINIO_ENDPOINT=https://s3.<region>.amazonaws.com
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=<generate: openssl rand -hex 16>
MINIO_SECRET_KEY=<generate: openssl rand -hex 32>
MINIO_BUCKET=cloudcampus-backups

# pgbackup sidecar also needs direct Postgres access:
PG_HOST=postgres
PG_PORT=5432
PG_DB=cloudcampus
PG_USER=cloudcampus
PGPASSWORD=<same as POSTGRES_PASSWORD>
RETENTION_DAYS=30
# GPG passphrase for AES-256 symmetric encryption of pg_dump archives.
# CRITICAL: Store this in AWS Secrets Manager / Vault. Loss of this passphrase
# means backups cannot be decrypted. Rotate annually.
BACKUP_PASSPHRASE=<generate: openssl rand -hex 32>
