                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"greenwood-high\",\n  \"schoolName\": \"Greenwood High\",\n  \"schemaName\": \"greenwood\",\n  \"logoUrl\": \"https://example.com/greenwood-logo.png\",\n  \"primaryColor\": \"#10b981\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tenants",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tenants"
              ]
