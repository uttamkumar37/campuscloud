{
  "info": {
    "name": "EduTenant API",
    "description": "Postman collection generated from existing CampusCloud controllers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Super Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "pm.environment.set(\"token\", response.data.accessToken);",
                  "pm.environment.set(\"username\", response.data.username);",
                  "pm.environment.set(\"role\", response.data.role);",
                  "pm.environment.set(\"tenantHeader\", pm.environment.get(\"publicTenantId\"));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"superadmin\",\n  \"password\": \"admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Super admin login without tenant schema."
          }
        },
        {
          "name": "Tenant User Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "pm.environment.set(\"token\", response.data.accessToken);",
                  "pm.environment.set(\"username\", response.data.username);",
                  "pm.environment.set(\"role\", response.data.role);",
                  "pm.environment.set(\"tenantHeader\", pm.environment.get(\"tenantSchema\"));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{tenantSchema}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"schooladmin\",\n  \"password\": \"StrongPass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Tenant-scoped login for SCHOOL_ADMIN, TEACHER, STUDENT, or PARENT users."
          }
        }
      ]
    },
