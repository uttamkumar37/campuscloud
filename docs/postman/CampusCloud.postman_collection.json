{
  "info": {
    "name": "CampusCloud API",
    "description": "REST API for CampusCloud (v1: baseUrl = http://localhost:8080/api/v1). Import `CampusCloud.local.postman_environment.json` and select it before running requests. See docs/API_REFERENCE.md.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1"
    },
    {
      "key": "apiRoot",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Super Admin Login (v1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.accessToken) {",
                  "  pm.environment.set(\"token\", json.data.accessToken);",
                  "}",
                  "if (json && json.data && json.data.username) pm.environment.set(\"username\", json.data.username);",
                  "if (json && json.data && json.data.role) pm.environment.set(\"role\", json.data.role);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"superadmin\",\n  \"password\": \"CHANGEME\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "No X-Tenant-ID required for bootstrap super admin. Password from BOOTSTRAP_ADMIN_PASSWORD."
          }
        },
        {
          "name": "Tenant User Login (v1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.accessToken) {",
                  "  pm.environment.set(\"token\", json.data.accessToken);",
                  "}",
                  "if (json && json.data && json.data.username) pm.environment.set(\"username\", json.data.username);",
                  "if (json && json.data && json.data.role) pm.environment.set(\"role\", json.data.role);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{tenantSchema}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"schooladmin\",\n  \"password\": \"CHANGEME\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "SCHOOL_ADMIN / TEACHER / etc. Must send X-Tenant-ID = tenant schema name."
          }
        },
        {
          "name": "Teacher Login",
          "event": [
            {
              "listen": "test",
              "script": {
