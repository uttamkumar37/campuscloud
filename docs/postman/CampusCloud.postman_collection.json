    {
      "name": "Tenants",
      "item": [
        {
          "name": "Create Tenant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{publicTenantId}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"greenwood-high\",\n  \"schoolName\": \"Greenwood High\",\n  \"schemaName\": \"greenwood\",\n  \"logoUrl\": \"https://example.com/logo.png\",\n  \"primaryColor\": \"#10b981\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tenants",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tenants"
              ]
            },
            "description": "Requires SUPER_ADMIN (typically)."
          }
        },
        {
          "name": "List Tenants",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{publicTenantId}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tenants",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tenants"
              ]
            }
          }
        },
        {
          "name": "Get Tenant by tenantId",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{publicTenantId}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tenants/{{targetTenantId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tenants",
                "{{targetTenantId}}"
              ]
            }
          }
        },
        {
          "name": "Subscribe Tenant to Plan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planId\": \"{{planId}}\",\n  \"durationDays\": 365\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tenants/{{targetTenantId}}/subscribe",
              "host": ["{{baseUrl}}"],
              "path": ["tenants", "{{targetTenantId}}", "subscribe"]
            },
            "description": "SUPER_ADMIN only. No X-Tenant-ID required."
          }
        },
        {
          "name": "Get Tenant Subscription",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tenants/{{targetTenantId}}/subscription",
              "host": ["{{baseUrl}}"],
              "path": ["tenants", "{{targetTenantId}}", "subscription"]
            },
            "description": "SUPER_ADMIN only. Returns null data if no active subscription."
          }
        },
        {
          "name": "Cancel Tenant Subscription",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tenants/{{targetTenantId}}/subscription",
              "host": ["{{baseUrl}}"],
              "path": ["tenants", "{{targetTenantId}}", "subscription"]
            },
            "description": "SUPER_ADMIN only. Sets subscription status to CANCELLED."
          }
        }
      ]
    },
