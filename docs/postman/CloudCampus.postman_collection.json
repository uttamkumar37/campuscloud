{
  "info": {
    "name": "CloudCampus Backend API (v1)",
    "description": "Local dev collection for the CloudCampus backend skeleton. Import `CloudCampus.local.postman_environment.json` and select it before running requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "apiRoot",
      "value": "http://localhost:8080"
    },
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/v1"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Actuator Health",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{apiRoot}}/actuator/health",
              "host": [
                "{{apiRoot}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Super Admin",
      "item": [
        {
          "name": "Tenants",
          "item": [
            {
              "name": "Create Tenant",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const json = pm.response.json();",
                      "if (json && json.data && json.data.id) {",
                      "  pm.environment.set(\"tenantUuid\", json.data.id);",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"code\": \"{{tenantCode}}\",\n  \"name\": \"{{tenantName}}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/super-admin/tenants",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "super-admin",
                    "tenants"
                  ]
                }
              }
            },
            {
              "name": "List Tenants",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/super-admin/tenants?offset=0&limit=20",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "super-admin",
                    "tenants"
                  ],
                  "query": [
                    {
                      "key": "offset",
                      "value": "0"
                    },
                    {
                      "key": "limit",
                      "value": "20"
                    }
                  ]
                }
              }
            },
            {
              "name": "Get Tenant",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/super-admin/tenants/{{tenantUuid}}",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "super-admin",
                    "tenants",
                    "{{tenantUuid}}"
                  ]
                }
              }
            }
          ]
        }
      ]
    }
  ]
}

